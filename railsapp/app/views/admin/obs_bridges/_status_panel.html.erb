<%# app/views/admin/obs_bridges/_status_panel.html.erb %>
<div
  id="obs_bridge_status_panel_<%= bridge_id %>"
  class="rounded border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-900"
>
  <h2 class="mb-4 text-lg font-medium">Bridge status</h2>

  <dl class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Desired state</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:desired_state] %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Runtime state</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:runtime_state] %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Connected</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:connected] %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Capture all active</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:capture_all_active] %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Capture all until</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:capture_all_until]&.iso8601 || "—" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Inventory scene count</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:inventory_scene_count] %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Inventory refreshed at</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:inventory_refreshed_at]&.iso8601 || "—" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Last heartbeat</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:last_heartbeat_at]&.iso8601 || "—" %></dd>
    </div>

    <div>
      <dt class="text-sm font-medium text-gray-500 dark:text-gray-400">Updated at</dt>
      <dd class="mt-1 font-mono text-gray-900 dark:text-gray-100"><%= status[:updated_at]&.iso8601 || "—" %></dd>
    </div>
  </dl>

  <% if status[:last_error].present? %>
    <div class="mt-4 rounded border border-red-300 bg-red-50 p-3 text-red-800 dark:border-red-800 dark:bg-red-950 dark:text-red-200">
      <div class="text-sm font-medium">Last error</div>
      <pre class="mt-2 whitespace-pre-wrap font-mono text-sm"><%= status[:last_error] %></pre>
    </div>
  <% end %>
</div>
