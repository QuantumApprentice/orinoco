<% content_for :title, "Twitch Chat" %>
<% content_for :body_class, "overflow-hidden" %>
<% content_for :main_class, "mx-auto w-full overflow-hidden px-5" %>

<div
  class="relative h-[calc(100dvh-4rem)] overflow-hidden"
  data-controller="chat-layout"
>
  <header
    class="absolute px-4 py-4 backdrop-blur"
    data-chat-layout-target="header"
  >
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-4">
      <div>
        <h1 class="text-3xl font-bold text-slate-50">Twitch Chat</h1>
        <p class="mt-1 text-sm text-slate-400">Connect a channel and watch incoming chat messages flow through the pipeline.</p>
      </div>

      <div class="flex flex-col gap-3">
        <% @twitch_configs.each do |cfg| %>
          <%= form_with model: cfg, class: "flex flex-col gap-3 rounded-lg border border-slate-800 bg-slate-900/70 p-4 md:flex-row md:items-end" do |chat| %>
            <div class="flex-1">
              <%= chat.label :channel_name, "Channel", class: "mb-2 block text-sm font-medium text-slate-200" %>
              <%= chat.text_field :channel_name,
                class: cx(
                  "block w-full rounded-md border px-3 py-2 shadow-sm",
                  "border-slate-700 bg-slate-950 text-slate-100",
                  "placeholder:text-slate-500",
                  "focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
                ) %>
            </div>

            <%= chat.submit "Connect",
              class: cx(
                "inline-flex items-center justify-center rounded-md px-4 py-2 text-sm font-medium shadow-sm",
                "bg-blue-600 text-white hover:bg-blue-700",
                "focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
                "focus:ring-offset-slate-900"
              ) %>
          <% end %>
        <% end %>
      </div>
    </div>
  </header>

  <main
    class="h-full bg-slate-950 px-4 py-4"
    data-chat-layout-target="body"
  >
    <%= turbo_stream_from :chat %>

    <div
      id="chat_feed"
      class="mx-auto flex h-full w-full max-w-6xl flex-col gap-3 overflow-y-auto pr-1"
      data-controller="autoscroll"
    >
      <%= render ChatMessageComponent.with_collection(@messages.compact) %>
    </div>
  </main>
</div>
