<div>
  <h1 class="font-bold text-4xl">ClipShow#index</h1>
  <p>Find me in app/views/clip_show/get_scenes.html.erb</p>

  <%-@scenes.keys.each do |val| %>
    <table>
      <tr>
        <th><%=val%></th>
      </tr>
      <%-@scenes[val].each do |inner_val| %>
        <tr>
          <td>
            <%=button_to inner_val[0],
            clip_show_play_path(clip_name:inner_val[0],id:inner_val[1],scene_name:val)%>
          </td>
        </tr>
      <%end%>
    </table>

  <%end%>
</div>
